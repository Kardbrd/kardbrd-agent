# kardbrd.yml — Declarative board automation rules
#
# Place this file at the root of your repository (next to CLAUDE.md).
# The agent loads it on startup and hot-reloads every 60 seconds.
#
# ── Format ────────────────────────────────────────────────────────────
#
# kardbrd.yml is a YAML dict with top-level config, optional schedules,
# and a rules list:
#
#   board_id: eykqek0W                # required: your board ID
#   agent: MBPBot                     # required: agent name for @mentions
#   api_url: http://app.kardbrd.com   # optional: defaults to KARDBRD_API_URL env var
#   executor: claude                  # optional: "claude" (default) or "goose"
#
#   schedules:                        # optional: cron-based automation
#     - name: "Daily Summary"
#       cron: "0 0 * * *"
#       action: summarize the board
#
#   rules:                            # event-driven automation
#     - name: "Rule name"
#       event: card_moved
#       action: /ke
#
# Set KARDBRD_BOT_TOKEN environment variable with the bot token.
#
# ── Rule Schema ───────────────────────────────────────────────────────
#
# Each rule connects:
#   1. An EVENT on the board (WebSocket event type)
#   2. Optional CONDITIONS that narrow the match
#   3. An ACTION — a prompt or skill command sent to Claude
#   4. An optional MODEL override (haiku, sonnet, opus)
#
#   - name: "Human-readable rule name"        # required
#     event: card_moved                       # required, string or YAML list
#     event:                                  # multi-event example:
#       - card_moved                          #   use a YAML list
#       - card_created
#     list: "Ideas"                           # condition: list name (case-insensitive)
#     title: "📦"                             # condition: exact card title match
#     label: "Bug"                            # condition: label name (case-insensitive)
#     content_contains: "@claude"             # condition: comment text (case-insensitive)
#     exclude_label: "Agent"                  # condition: skip if card has this label
#     require_label: "Agent"                  # condition: card must have this label
#     emoji: "✅"                             # condition: reaction emoji (exact match)
#     require_user: "abc123"                  # condition: user ID who triggered the event
#     assignee:                               # condition: card assignee user ID(s)
#       - "01JM5K2B3N4PXQR7D8HMFY6W1A"       #   must be a YAML list (not a string)
#     model: haiku                            # optional: haiku | sonnet | opus
#     action: /ke                             # required: skill or prompt
#     action: __stop__                        # reserved: kills active session (no Claude spawn)
#
# ── Available Events (24 total) ─────────────────────────────────────
#
# Card events:
#   card_created        — New card added to a list
#   card_moved          — Card moved to a different list
#   card_archived       — Card archived
#   card_unarchived     — Archived card restored
#   card_deleted        — Card permanently deleted
#
# Comment events:
#   comment_created     — New comment posted (bot comments excluded)
#   comment_deleted     — Comment deleted
#
# Reaction events:
#   reaction_added      — Emoji reaction added to a comment
#
# Checklist events:
#   checklist_created   — New checklist added to a card
#   checklist_deleted   — Checklist removed from a card
#
# Todo item events:
#   todo_item_created   — Todo item added to a checklist
#   todo_item_completed — Todo item marked as done
#   todo_item_reopened  — Completed todo item marked incomplete
#   todo_item_deleted   — Todo item removed
#   todo_item_assigned  — User assigned to a todo item
#   todo_item_unassigned — User removed from a todo item
#
# Attachment events:
#   attachment_created  — File attached to a card
#   attachment_deleted  — Attachment removed from a card
#
# Link events:
#   card_link_created   — External URL added to a card
#   card_link_deleted   — Link removed from a card
#
# Label events:
#   label_added         — Label applied to a card
#   label_removed       — Label removed from a card
#
# List events:
#   list_created        — New list added to the board
#   list_deleted        — List removed from the board
#
# ── Condition Fields ────────────────────────────────────────────────
#
#   list:              Matches the destination list name (card_created,
#                      card_moved). Case-insensitive.
#   title:             Matches the card title exactly.
#   label:             Matches the label name (label_added, label_removed).
#                      Case-insensitive.
#   content_contains:  Matches substring in comment text
#                      (comment_created). Case-insensitive.
#   exclude_label:     Rejects the match if the card has this label.
#                      Case-insensitive. Fetches card labels from API.
#   require_label:     Card must have this label to match.
#                      Fetched from API at match time. Case-insensitive.
#   emoji:             Matches the emoji in a reaction_added event.
#                      Exact string match (server normalizes Unicode).
#   require_user:      Matches the user_id of who triggered the event.
#                      Exact string match. Use to restrict who can
#                      trigger sensitive actions (e.g., deploy).
#
# ── Reserved Actions ──────────────────────────────────────────────
#
#   __stop__           Kills the active Claude session for the card.
#                      Executes deterministically (no Claude spawn).
#                      Typically used with emoji: "🛑" reactions.
#
# ── Schedules ──────────────────────────────────────────────────────
#
# Cron-based schedules run independently of WebSocket events.
# Each schedule has a `name` that doubles as the card title — the
# scheduler finds an existing card with that name (case-insensitive)
# or creates a new one. The action then runs in that card's context.
#
#   schedules:
#     - name: Daily Summary          # card title (find or create)
#       cron: "0 0 * * *"            # standard cron expression
#       model: haiku                 # optional: haiku | sonnet | opus
#       list: Ideas                  # optional: target list for new cards
#       assignee: E21K9jmv           # optional: user ID to assign new cards
#       action: |
#         Read the activity on the board for the previous day...
#
# Schedule fields:
#   name:      Required. The card title. Used to find or create the card.
#   cron:      Required. Standard cron expression (5 fields: min hour dom mon dow).
#   action:    Required. Prompt or skill command to run.
#   model:     Optional. haiku | sonnet | opus.
#   list:      Optional. Target list for newly created cards.
#   assignee:  Optional. User ID to assign when creating a new card.
#              Existing cards keep their current assignee.
#
# Notes:
# - Schedules use `croniter` for cron parsing.
# - The ScheduleManager runs as a third asyncio.gather() task alongside
#   WebSocket and status ping.
# - If the agent was offline when a cron was due, the missed run is
#   NOT executed on startup.
# - Schedules reuse the same executor pipeline as rules (semaphore,
#   worktree, per-card deduplication).
#   assignee:          Matches the card's assignee user ID. Must be a
#                      YAML list of user ID strings (not comma-separated).
#                      Case-sensitive (IDs are exact). Fetches card from API.
#                      Unassigned cards never match.
#
# ── Notes ───────────────────────────────────────────────────────────
#
# - Rules are checked AFTER built-in handlers (@mention, done-cleanup).
#   Reactions (🛑 stop, 🔄 retry, etc.) are handled entirely via rules.
# - All matching rules fire — if two rules match, both spawn separate
#   Claude sessions.
# - Per-card deduplication prevents two sessions for the same card.
# - The file is hot-reloaded every 60 seconds; changes take effect
#   without restarting the agent.
# - Model names resolve to latest versions:
#     haiku  → claude-haiku-4-5-20251001
#     sonnet → claude-sonnet-4-5-20250929
#     opus   → claude-opus-4-6
#
# ── Per-User Workflows ────────────────────────────────────────────
#
# The `assignee` condition enables per-user automation. Each developer
# can define rules that fire only for cards assigned to them. This
# makes kardbrd.yml the central place where users store and share
# their workflows — checked into the repo, versioned with the code.
#
# Find user IDs from the board's member list or card API responses.
#
# ── Examples ────────────────────────────────────────────────────────
---
board_id: eykqek0W
agent: MyBot
api_url: http://app.kardbrd.com

schedules:
  # Daily activity summary — runs at midnight UTC
  - name: Daily Summary
    cron: "0 0 * * *"
    model: haiku
    list: Ideas
    action: |
      Read the activity on the board for the previous day using
      `kardbrd md board <board_id>` and summarize
      by human their activity on the board. Post the summary
      as a comment on this card.

  # Weekly backlog grooming — runs every Monday at 9am UTC
  - name: Weekly Backlog Review
    cron: "0 9 * * 1"
    model: sonnet
    list: Ideas
    assignee: abc123
    action: |
      Review all cards on the board. Identify cards that have been
      stale for more than a week (no comments or updates). Post a
      summary of stale cards as a comment on this card with
      recommendations for each: archive, re-prioritize, or discuss.

rules:
  # When a card lands in the Ideas list, explore it immediately
  - name: Explore ideas
    event:
      - card_created
      - card_moved
    list: Ideas
    action: /ke

  # Cards titled exactly "📦" trigger a deploy pipeline
  - name: Box card ships
    event: card_created
    model: haiku
    title: "📦"
    action: |
      Run `make test-all`, publish the report on the card,
      then run `make prod-deploy` if everything is green.

  # Moving a card to "In Progress" starts implementation
  - name: In progress starts coding
    event: card_moved
    list: In Progress
    action: |
      Implement the card in code and report what you did back
      to the card. Don't forget to commit your changes.

  # Adding the "exploration" label triggers deep exploration
  - name: Exploration label
    event: label_added
    label: exploration
    action: /ke

  # Respond to comments that mention @claude
  - name: Respond to mentions
    event: comment_created
    content_contains: "@claude"
    action: respond to the comment on this card

  # Automate cards in Ideas, but skip cards labeled "Agent"
  - name: Explore non-agent ideas
    event: card_moved
    list: Ideas
    exclude_label: Agent
    action: /ke

  # Archive event cleanup
  - name: Clean up on archive
    event: card_archived
    model: haiku
    action: |
      Post a summary of the card's status as a final comment.

  # New checklist triggers a plan review
  - name: Review new checklists
    event: checklist_created
    model: sonnet
    action: |
      Review the new checklist on this card. Check if the items
      are actionable and well-defined. Post suggestions as a comment.

  # ── Reaction-based rules ──────────────────────────────────────────

  # Stop active agent session (deterministic, no Claude spawn)
  - name: Stop agent
    event: reaction_added
    emoji: "🛑"
    action: __stop__

  # Ship card when operator approves the review with ✅
  - name: Ship on approval
    event: reaction_added
    emoji: "✅"
    require_user: "abc123"
    model: sonnet
    action: |
      The operator approved the review. Merge the PR to main.

  # Re-run review via 🔄 reaction
  - name: Re-run review
    event: reaction_added
    emoji: "🔄"
    model: opus
    action: /kr

  # ── Assignee-based rules ──────────────────────────────────────────

  # Only fire for a specific developer (assignee must be a YAML list)
  - name: Alice's auto-implement
    event: card_moved
    list: In Progress
    assignee:
      - "01JM5K2B3N4PXQR7D8HMFY6W1A"
    action: |
      Implement the card requirements and commit changes.

  # Fire for any team lead (multiple IDs in YAML list)
  - name: Team leads review
    event: card_moved
    list: Review
    assignee:
      - "01JM5K2B3N4PXQR7D8HMFY6W1A"
      - "01JM8R4C6Q7SYUL9F2KNGZ3X5B"
    action: |
      Review the implementation on this card.
